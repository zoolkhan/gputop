#!/bin/bash
# This wrapper script runs the gputop Python application using its virtual environment.

SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
VENV_PYTHON="$SCRIPT_DIR/venv/bin/python3"
# Point to gputop_v0.2.py for now, as main.py is missing.
# We will create main.py for v0.3 development later.
APP_SCRIPT="$SCRIPT_DIR/gputop_v0.2.py" 

# Check if virtual environment Python exists
if [ ! -f "$VENV_PYTHON" ]; then
    echo "Error: Virtual environment Python not found at $VENV_PYTHON"
    echo "Please ensure the virtual environment is set up and blessed is installed: "
    echo "cd $SCRIPT_DIR && python3 -m venv venv && ./venv/bin/pip install -r requirements.txt"
    exit 1
fi

# Execute the Python application using the venv's Python
exec "$VENV_PYTHON" "$APP_SCRIPT" "$@"
